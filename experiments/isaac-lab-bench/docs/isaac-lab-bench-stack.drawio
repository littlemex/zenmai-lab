        </mxCell>

        <!-- benchmark_rsl_rl.py -->
        <mxCell id="benchmark" value="&lt;b&gt;scripts/benchmarks/benchmark_rsl_rl.py&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#FFEE99&quot;&gt;★ ボトルネック調査の着地点&lt;/font&gt;&lt;br&gt;計測: App Launch Time / Total Start Time&lt;br&gt;　　  Mean Total FPS / Mean Collection FPS / Max Rewards&lt;br&gt;stdout: &amp;quot;&amp;lt;key&amp;gt;: &amp;lt;value&amp;gt; ms&amp;quot; 形式 → run_bench.sh が grep 解析" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7FB069;strokeColor=#5A8A47;fontColor=#ffffff;fontSize=10;align=left;verticalAlign=middle;spacingLeft=5;" vertex="1" parent="1">
