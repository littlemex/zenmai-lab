        </mxCell>
        <mxCell id="op_dcv" value="&lt;b&gt;Operator (EC2 / DCV端末)&lt;/b&gt;&lt;br&gt;DCVモード&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;bash 直接実行&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#AAAAAA;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="240" y="140" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- orchestrate.sh（SSMモード専用） -->
        <mxCell id="orchestrate" value="&lt;b&gt;orchestrate.sh&lt;/b&gt;  &lt;font color=&quot;#CCEECC&quot;&gt;SSMモード専用&lt;/font&gt;&lt;br&gt;1. ssm.env 読み込み (INSTANCE_ID, AWS_REGION)&lt;br&gt;2. run_bench.sh を Base64 でSSM転送&lt;br&gt;3. SWEEP ループ: run_one() → nohup起動 → pgrep ポーリング (4秒)&lt;br&gt;4. 完了後 tar.gz でリモート結果取得 → results/&amp;lt;tag&amp;gt;/&lt;br&gt;5. dmon_stats.py をローカル実行（Mac側）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4DA6FF;strokeColor=#2E7FCC;fontColor=#ffffff;fontSize=10;align=left;verticalAlign=middle;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="20" y="230" width="220" height="96" as="geometry" />
        </mxCell>

        <!-- SWEEP注記 -->
        <mxCell id="note_sweep" value="&lt;i&gt;g1-num-envs SWEEP ループ:&lt;br&gt;4096 → 8192 → 16384 (num_envs)&lt;br&gt;orchestrate.sh L200&lt;/i&gt;" style="text;html=1;strokeColor=#CCAA44;fillColor=#FFFDE7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="20" y="336" width="220" height="46" as="geometry" />
        </mxCell>

        <!-- run_bench.sh -->
        <mxCell id="run_bench" value="&lt;b&gt;scripts/run_bench.sh&lt;/b&gt;  &lt;font color=&quot;#CCEECC&quot;&gt;EC2上で実行（両モード共通）&lt;/font&gt;&lt;br&gt;for SEED in $SEEDS: (シードループ)&lt;br&gt;  nvidia-smi dmon -s upcm -d 1 &amp;amp; → dmon.log&lt;br&gt;  python benchmark_rsl_rl.py --task --headless …&lt;br&gt;  grep → App Launch / FPS 抽出 → summary.csv" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4DA6FF;strokeColor=#2E7FCC;fontColor=#ffffff;fontSize=10;align=left;verticalAlign=middle;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="20" y="396" width="360" height="86" as="geometry" />
        </mxCell>

        <!-- dmon_stats.py（Mac側・zenmai-lab列） -->
        <mxCell id="dmon_stats" value="&lt;b&gt;scripts/dmon_stats.py&lt;/b&gt;  &lt;font color=&quot;#CCEECC&quot;&gt;Mac（ローカル）で実行&lt;/font&gt;&lt;br&gt;nvidia-smi-dmon.log を集計&lt;br&gt;SM% avg/p95/max, MEM%, PWR, MCLK/PCLK&lt;br&gt;出力: text / csv / md（レポート用）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4DA6FF;strokeColor=#2E7FCC;fontColor=#ffffff;fontSize=10;align=left;verticalAlign=middle;spacingLeft=5;" vertex="1" parent="1">
