        <!-- オペレーター層 -->
        <mxCell id="op_ssm" value="&lt;b&gt;Operator (Mac / laptop)&lt;/b&gt;&lt;br&gt;SSM モード&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;aws ssm send-command&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#AAAAAA;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
