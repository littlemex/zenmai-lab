# Shared environment variables for all experiments.
# Copy to common/infra/env (which is gitignored) and edit.

# AWS
export AWS_REGION="ap-northeast-1"
export AWS_ACCOUNT_ID="<your-12-digit-account-id>"

# ECR registry (derived)
export ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"

# S3 bucket for large artifacts (datasets, checkpoints, videos)
export S3_BUCKET="<your-zenmai-lab-bucket>"
