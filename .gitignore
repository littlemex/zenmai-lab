# secrets / per-experiment env
push.env
*.env
!*.env.sample

# results: bench output stays local; only CSVs and explicit notes are tracked
**/results/**
!**/results/**/
!**/results/**/*.csv
!**/results/**/.gitkeep
# py-spy decoded artifacts are small Markdown / SVG that we ship to customers
!**/results/pyspy/*.svg
!**/results/pyspy/*.tree.md

# python
__pycache__/
*.pyc
.venv/
.python-version

# editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# build artifacts
.docker-build-cache/

# nsys profile reports (huge; only the derived CSV / txt summaries are committed)
*.nsys-rep
*.sqlite
